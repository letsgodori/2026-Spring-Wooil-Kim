# 👀 4. 백그라운드 무한 감시 봇 로직
# ==========================================
def monitor_dart_announcements():
    global RECOMMENDED_STOCKS
    try:
        today = datetime.now().strftime('%Y%m%d')
        reports = dart.list(start=today)
        if reports is None or reports.empty: return
        
        reports = reports[reports['report_nm'].str.contains('영업(잠정)실적', regex=False, na=False)]
        if reports.empty: return

        for index, row in reports.iterrows():
            report_id = row['rcept_no']
            
            if str(report_id) in processed_reports: continue
            
            corp_code, corp_name = row['corp_code'], row['corp_name']
            
            target_row = corp_codes_df[corp_codes_df['corp_code'] == corp_code]
            if target_row.empty or pd.isna(target_row['stock_code'].iloc[0]):
                mark_as_processed(report_id)
                continue
                
            ticker = str(target_row['stock_code'].iloc[0]).strip().zfill(6)
            print(f"📢 새 실적 공시 뜸!: [{corp_name}]")
            
            extracted_data = extract_actual_earnings(report_id)
            if extracted_data == "NOT_READY": continue
            if extracted_data is None:
                mark_as_processed(report_id)
                continue
                
            result = run_quant_analysis(ticker, extracted_data, corp_name)
            
            if result:
                print(f"🎯 [웹 대시보드 전송 완료!] 합격 종목: {result['name']}")
                
                try:
                    conn = sqlite3.connect('quant_system.db')
                    cursor = conn.cursor()
                    cursor.execute("SELECT 커스텀_섹터 FROM stock_sectors WHERE 종목코드 = ?", (ticker,))
                    db_result = cursor.fetchone()
                    sector = db_result[0] if db_result else "기타"
                    conn.close()
                except:
                    sector = "기타"
                
                result['sector'] = sector
                result['caught_time'] = datetime.now().strftime('%H:%M:%S')
                RECOMMENDED_STOCKS.append(result)
            
            mark_as_processed(report_id)
            time.sleep(1) # 차단 위험이 없어졌으므로 1초만 가볍게 쉼

    except Exception:
        pass

def run_bot_in_background():
    print("🤖 알고리즘 가동 시작. (1분 주기 감시 시작)")
    monitor_dart_announcements()
    schedule.every(1).minutes.do(monitor_dart_announcements)
    while True:
        schedule.run_pending()
        time.sleep(1)

