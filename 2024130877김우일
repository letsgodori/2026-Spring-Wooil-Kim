# 🌐 5. FastAPI 웹 서버 프론트엔드/백엔드
# ==========================================
@asynccontextmanager
async def lifespan(app: FastAPI):
    bot_thread = threading.Thread(target=run_bot_in_background, daemon=True)
    bot_thread.start()
    yield

app = FastAPI(lifespan=lifespan)

