# 🕷️ 2. DART 공시 본문 표 크롤링 엔진
# ==========================================
def extract_actual_earnings(report_id):
    document_text = None
    is_not_ready = False
    
    for i in range(3):
        try:
            document_text = dart.document(report_id)
            if document_text: break
        except Exception as e:
            if '014' in str(e):
                print(f"   >> ⏳ DART 서버 문서 생성 대기 중... ({i+1}/3)")
                time.sleep(3)
                is_not_ready = True
            else:
                break

    if not document_text:
        return "NOT_READY" if is_not_ready else None

    try:
        tables = pd.read_html(io.StringIO(document_text))
        for df in tables:
            df_str = df.astype(str).replace('\s+', '', regex=True)
            op_row_mask = df_str.apply(lambda row: row.astype(str).str.contains('영업이익|영업손익').any(), axis=1)
            op_row_idx = df_str[op_row_mask].index
            
            if not op_row_idx.empty:
                op_row = df.iloc[op_row_idx[0]]
                numbers = []
                for val in op_row:
                    val_str = str(val).replace(',', '').strip()
                    num_match = re.search(r'^-?\d+\.?\d*', val_str)
                    if num_match:
                        numbers.append(float(num_match.group()))
                
                if len(numbers) >= 3:
                    return {
                        'op_q0': numbers[0],
                        'op_q_qoq': numbers[1],
                        'op_q_yoy': numbers[3] if len(numbers) >= 4 else numbers[2],
                        'ocf': 1
                    }
        return None
    except Exception:
        return None

# ==========================================
# 🧠 3. 핵심 퀀트 분석 엔진 (fdr 우회 버전)
# ==========================================
def run_quant_analysis(ticker, financial_data, corp_name):
    q0 = financial_data.get('op_q0', 0)
    q_yoy = financial_data.get('op_q_yoy', 0)
    q_qoq = financial_data.get('op_q_qoq', 0)
    ocf = financial_data.get('ocf', 0)
    
    yoy_growth = ((q0 / q_yoy) - 1) * 100 if q_yoy > 0 else (100 if q0 > 0 else -100)
    qoq_growth = ((q0 / q_qoq) - 1) * 100 if q_qoq > 0 else (100 if q0 > 0 else -100)

    if yoy_growth < 30: return None
    if qoq_growth < 10: return None
    if ocf <= 0: return None

    # 💡 [핵심 패치 2] 거래소 서버에 요청하지 않고, 프로그램 시작 시 받아둔 마스터 테이블에서 꺼내 씀
    try:
        target_info = stock_master_df[stock_master_df['Code'] == ticker]
        if target_info.empty: return None
        
        market_cap = target_info['Marcap'].iloc[0] # 시가총액 (원)
        if market_cap > 300_000_000_000: return None 
        
        # 1달 수익률은 차단 위험이 적은 야후 파이낸스/네이버에서 가져옴
        one_month_ago = (datetime.today() - pd.Timedelta(days=30)).strftime("%Y-%m-%d")
        df_price = fdr.DataReader(ticker, one_month_ago)
        if df_price.empty: return None
        
        start_price = df_price['Close'].iloc[0]
        end_price = df_price['Close'].iloc[-1]
        price_return = (end_price / start_price - 1) * 100
        if price_return >= 10: return None 
            
    except Exception as e:
        return None

    return {
        "ticker": ticker, 
        "name": corp_name, 
        "market_cap": int(market_cap / 100000000),
        "yoy": round(yoy_growth, 1),
        "qoq": round(qoq_growth, 1),
        "return": round(price_return, 1)
    }

